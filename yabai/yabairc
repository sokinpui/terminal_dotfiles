# vi: set ft=conf

killall borders 2>/dev/null
borders active_color=0xff4eed32 inactive_color=0xff494d64 width=5.0 hidpi=on &

yabai -m config layout                      bsp
yabai -m config auto_balance                off
yabai -m config top_padding                 5
yabai -m config bottom_padding              5
yabai -m config left_padding                5
yabai -m config right_padding               5
yabai -m config window_gap                  5

# New window spawns to the right if vertical split, or bottom if horizontal split
yabai -m config window_placement second_child
# yabai -m config window_topmost              on
yabai -m config split_type              auto

# floating windows are always on top (default: off)

yabai -m config mouse_modifier              cmd
yabai -m config focus_follows_mouse         autofocus
# yabai -m config mouse_follows_focus         on

# enable debug on
yabai -m config debug_output                off

# disable those app
yabai -m rule --add app="App Store"  manage=off
yabai -m rule --add app="Logi Options+"  manage=off
yabai -m rule --add app="WeChat"  manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="V2rayU" manage=off
yabai -m rule --add app="Karabiner-Elements" manage=off
yabai -m rule --add app="Karabiner-EventViewer" manage=off
yabai -m rule --add app="System Information" manage=off
yabai -m rule --add app="Raycast" manage=off
yabai -m rule --add app="minecraft" manage=off
yabai -m rule --add app="java" manage=off
yabai -m rule --add app="Logi Options" manage=off

