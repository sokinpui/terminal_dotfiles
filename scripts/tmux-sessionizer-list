#!/usr/bin/env bash

set -euo pipefail

readonly SCRIPT_DIR="$(dirname "$0")"
source "$SCRIPT_DIR/tmux-sessionizer-meta"

# 1. List local results
"$SCRIPT_DIR/tmux-sessionizer-list-local"

# 2. List remote results by calling only the local-list script on remotes
for host in "${SSH_HOSTS[@]}"; do
  ssh -o ConnectTimeout=2 "$host" "zsh -l -c 'tmux-sessionizer-list-local'" 2>/dev/null |
    sed "s|^|$host:| "
done
