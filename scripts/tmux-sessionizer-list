#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "$0")/tmux-sessionizer-meta"

SEARCH_DIRECTORIES=()

for dir in "${INITIAL_DIRECTORIES[@]}"; do
  if [[ -d "$dir" ]]; then
    SEARCH_DIRECTORIES+=("$dir")
  fi
done

[[ ${#SEARCH_DIRECTORIES[@]} -eq 0 ]] && exit 0

exclusions=()
for ignored_path in "${IGNORED_PATHS[@]}"; do
  exclusions+=("-not" "-path" "$ignored_path")
done

find "${SEARCH_DIRECTORIES[@]}" \
  -mindepth 0 -maxdepth 1 -type d \
  "${exclusions[@]}" \
  -not -path '*/.*' \
  -not -path '*/*.wt' \
  -exec ls -1dt {} + | uniq

for host in "${SSH_HOSTS[@]}"; do
  ssh -o ConnectTimeout=2 "$host" "zsh -l -c 'tmux-sessionizer-list'" 2>/dev/null | while read -r line; do
    echo "$host:$line"
  done
done
